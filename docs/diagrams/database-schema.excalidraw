    {"type":"text","id":"migration_files_body","x":70,"y":872,"width":440,"height":202,"text":"000001_create_users_table.up.sql\n  CREATE TABLE users (...)\n\n000002_create_devices_table.up.sql\n  CREATE TABLE devices (...)\n  CREATE INDEX idx_devices_user_id\n  CREATE INDEX idx_devices_device_identifier\n\n000003_create_patient_caretakers_table.up.sql\n  CREATE TABLE patient_caretakers (...)\n  CREATE INDEX idx_pc_caretaker_id","originalText":"000001_create_users_table.up.sql\n  CREATE TABLE users (...)\n\n000002_create_devices_table.up.sql\n  CREATE TABLE devices (...)\n  CREATE INDEX idx_devices_user_id\n  CREATE INDEX idx_devices_device_identifier\n\n000003_create_patient_caretakers_table.up.sql\n  CREATE TABLE patient_caretakers (...)\n  CREATE INDEX idx_pc_caretaker_id","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8005,"version":1,"versionNonce":8006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

