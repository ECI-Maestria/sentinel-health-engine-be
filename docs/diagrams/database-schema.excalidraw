    {"type":"text","id":"conn_info_body","x":590,"y":872,"width":440,"height":202,"text":"Host:  Azure PostgreSQL Flexible Server\nDB:    sentineldb\nUser:  sentineladmin\nPort:  5432 (TLS required)\n\nGORM Models:\n  type User struct { ... gorm.Model }\n  type Device struct { ... gorm.Model }\n  type PatientCaretaker struct { ... }\n\nMigrations:\n  golang-migrate/migrate v4\n  source: file://migrations\n  driver: pgx/v5","originalText":"Host:  Azure PostgreSQL Flexible Server\nDB:    sentineldb\nUser:  sentineladmin\nPort:  5432 (TLS required)\n\nGORM Models:\n  type User struct { ... gorm.Model }\n  type Device struct { ... gorm.Model }\n  type PatientCaretaker struct { ... }\n\nMigrations:\n  golang-migrate/migrate v4\n  source: file://migrations\n  driver: pgx/v5","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":9005,"version":1,"versionNonce":9006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5}
