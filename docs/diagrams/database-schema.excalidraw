    {"type":"text","id":"legend_txt","x":72,"y":1110,"width":960,"height":50,"text":"Legend:  🔑 Primary Key    🔗 Foreign Key    PK = PRIMARY KEY    FK = FOREIGN KEY    UNIQUE = unique constraint\nRelationships:  ─|  (one side, bar notation)    users 1 ←→ ∞ devices    users 1 ←→ ∞ patient_caretakers","originalText":"Legend:  🔑 Primary Key    🔗 Foreign Key    PK = PRIMARY KEY    FK = FOREIGN KEY    UNIQUE = unique constraint\nRelationships:  ─|  (one side, bar notation)    users 1 ←→ ∞ devices    users 1 ←→ ∞ patient_caretakers","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":7003,"version":1,"versionNonce":7004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

