    {"type":"text","id":"pc_cols","x":592,"y":144,"width":436,"height":202,"text":"🔑🔗 patient_id    UUID  NOT NULL  FK → users(id)  PK (1/2)\n🔑🔗 caretaker_id  UUID  NOT NULL  FK → users(id)  PK (2/2)\n🔗   linked_by     UUID  NOT NULL  FK → users(id)\n     created_at   TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n\n«Composite PK»  (patient_id, caretaker_id)\n\nCONSTRAINT: patient must have role = PATIENT\nCONSTRAINT: caretaker must have role = CARETAKER\n\nINDEX: idx_pc_caretaker_id  ON patient_caretakers(caretaker_id)","originalText":"🔑🔗 patient_id    UUID  NOT NULL  FK → users(id)  PK (1/2)\n🔑🔗 caretaker_id  UUID  NOT NULL  FK → users(id)  PK (2/2)\n🔗   linked_by     UUID  NOT NULL  FK → users(id)\n     created_at   TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n\n«Composite PK»  (patient_id, caretaker_id)\n\nCONSTRAINT: patient must have role = PATIENT\nCONSTRAINT: caretaker must have role = CARETAKER\n\nINDEX: idx_pc_caretaker_id  ON patient_caretakers(caretaker_id)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":4007,"version":1,"versionNonce":4008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

