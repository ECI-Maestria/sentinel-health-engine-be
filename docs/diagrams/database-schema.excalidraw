    {"type":"text","id":"users_cols","x":72,"y":144,"width":316,"height":258,"text":"🔑 id              UUID          PK  DEFAULT uuid_generate_v4()\n   email           VARCHAR(255)  NOT NULL  UNIQUE\n   password_hash   VARCHAR(255)  NOT NULL\n   role            VARCHAR(20)   NOT NULL  CHECK IN (DOCTOR, PATIENT, CARETAKER)\n   first_name      VARCHAR(100)  NOT NULL\n   last_name       VARCHAR(100)  NOT NULL\n   is_active       BOOLEAN       NOT NULL  DEFAULT TRUE\n   created_at      TIMESTAMPTZ   NOT NULL  DEFAULT NOW()\n   updated_at      TIMESTAMPTZ   NOT NULL  DEFAULT NOW()","originalText":"🔑 id              UUID          PK  DEFAULT uuid_generate_v4()\n   email           VARCHAR(255)  NOT NULL  UNIQUE\n   password_hash   VARCHAR(255)  NOT NULL\n   role            VARCHAR(20)   NOT NULL  CHECK IN (DOCTOR, PATIENT, CARETAKER)\n   first_name      VARCHAR(100)  NOT NULL\n   last_name       VARCHAR(100)  NOT NULL\n   is_active       BOOLEAN       NOT NULL  DEFAULT TRUE\n   created_at      TIMESTAMPTZ   NOT NULL  DEFAULT NOW()\n   updated_at      TIMESTAMPTZ   NOT NULL  DEFAULT NOW()","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2007,"version":1,"versionNonce":2008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.55},

