    {"type":"text","id":"devices_cols","x":72,"y":494,"width":436,"height":322,"text":"🔑 id                UUID   PK  DEFAULT uuid_generate_v4()\n🔗 user_id            UUID   NOT NULL  FK → users(id)\n                            ON DELETE CASCADE\n   device_identifier VARCHAR(255) NOT NULL  UNIQUE\n   fcm_token         TEXT\n   platform          VARCHAR(10)  NOT NULL\n                            CHECK IN (ANDROID, IOS)\n   name              VARCHAR(100) NOT NULL\n   is_active         BOOLEAN  NOT NULL  DEFAULT TRUE\n   last_seen_at      TIMESTAMPTZ\n   created_at        TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n   updated_at        TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n\nINDEX: idx_devices_user_id\nINDEX: idx_devices_device_identifier","originalText":"🔑 id                UUID   PK  DEFAULT uuid_generate_v4()\n🔗 user_id            UUID   NOT NULL  FK → users(id)\n                            ON DELETE CASCADE\n   device_identifier VARCHAR(255) NOT NULL  UNIQUE\n   fcm_token         TEXT\n   platform          VARCHAR(10)  NOT NULL\n                            CHECK IN (ANDROID, IOS)\n   name              VARCHAR(100) NOT NULL\n   is_active         BOOLEAN  NOT NULL  DEFAULT TRUE\n   last_seen_at      TIMESTAMPTZ\n   created_at        TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n   updated_at        TIMESTAMPTZ  NOT NULL  DEFAULT NOW()\n\nINDEX: idx_devices_user_id\nINDEX: idx_devices_device_identifier","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3007,"version":1,"versionNonce":3008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

