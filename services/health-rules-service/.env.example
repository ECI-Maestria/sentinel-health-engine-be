# ============================================================
# Health Rules Service — Environment Variables
# ============================================================

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://sbns-sentinel-he.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...

# Topic and subscription to consume telemetry events
TELEMETRY_TOPIC_NAME=telemetry-received
TELEMETRY_SUBSCRIPTION_NAME=health-rules-service

# Topic for publishing detected anomalies
ANOMALY_TOPIC_NAME=anomaly-detected

# Service
PORT=8080
LOG_LEVEL=info
SERVICE_NAME=health-rules-service
