# ============================================================
# User Service — Environment Variables
# Copy this file to .env and fill in the real values.
# ============================================================

# PostgreSQL — Azure Flexible Server (or local Postgres for dev)
# Format: postgres://user:password@host:5432/dbname?sslmode=require
# Azure example:
#   DATABASE_URL=postgres://adminuser:P@ssword@pg-sentinel-he.postgres.database.azure.com:5432/sentinel_users?sslmode=require
# Local Postgres example (if running pg in Docker):
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinel_users?sslmode=disable
DATABASE_URL=postgres://user:password@host:5432/sentinel_users?sslmode=require

# JWT — symmetric secret for signing access + refresh tokens.
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Internal API key — shared secret for service-to-service calls.
# Must match USER_SERVICE_API_KEY in telemetry-service and alerts-service.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change-me-must-match-other-services

# Azure Communication Services (Email) — optional.
# If empty, welcome and password-reset emails are silently skipped.
# Get from: Azure portal → ACS resource → Keys
ACS_CONNECTION_STRING=endpoint=https://acs-sentinel-he.communication.azure.com/;accesskey=...
ACS_SENDER_ADDRESS=DoNotReply@your-domain.azurecomm.net

# CORS — comma-separated list of allowed origins.
# Use "*" (or leave empty) to allow all origins during local development.
# In production, list exact origins: https://web.yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# Service
PORT=8080
LOG_LEVEL=info
