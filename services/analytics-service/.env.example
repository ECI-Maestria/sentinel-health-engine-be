# Azure Cosmos DB
COSMOS_ENDPOINT=https://cosmos-sentinel-he.documents.azure.com:443/
COSMOS_KEY=your-primary-key==
COSMOS_DATABASE=sentinel-health
COSMOS_TELEMETRY_CONTAINER=telemetry
COSMOS_ALERTS_CONTAINER=alerts

# JWT — must match user-service JWT_SECRET
JWT_SECRET=change-me

# Service
PORT=8080
LOG_LEVEL=debug
