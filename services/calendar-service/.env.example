# PostgreSQL — same server as user-service, different database
# Local Docker: use postgres hostname, sslmode=disable
# Azure: use Azure PostgreSQL hostname, sslmode=require
CALENDAR_DATABASE_URL=postgres://postgres:postgres@postgres:5432/sentinel_calendar?sslmode=disable

# JWT — must match user-service JWT_SECRET
JWT_SECRET=change-me

# user-service internal API (for notification worker)
USER_SERVICE_URL=http://user-service:8080
USER_SERVICE_API_KEY=change-me

# Azure Communication Services (email notifications)
ACS_CONNECTION_STRING=endpoint=https://<your-acs>.communication.azure.com/;accesskey=<base64key>
ACS_SENDER_ADDRESS=DoNotReply@<your-acs-domain>.azurecomm.net

# Firebase Cloud Messaging (push notifications)
# Use one of the two options below:
FIREBASE_CREDENTIALS_JSON=<base64-encoded-service-account-json>
# FIREBASE_CREDENTIALS_FILE=/path/to/serviceAccount.json

# Service
PORT=8080
LOG_LEVEL=debug
