# ============================================================
# Alerts Service — Environment Variables
# ============================================================

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://sbns-sentinel-he.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...
ANOMALY_TOPIC_NAME=anomaly-detected
ANOMALY_SUBSCRIPTION_NAME=alerts-service

# Azure Cosmos DB
COSMOS_ENDPOINT=https://cosmos-sentinel-he.documents.azure.com:443/
COSMOS_KEY=your-primary-key==
COSMOS_DATABASE=sentinel-health
COSMOS_ALERTS_CONTAINER=alerts

# Firebase Cloud Messaging
# Option A: path to JSON credentials file (recommended for local dev)
FIREBASE_CREDENTIALS_FILE=/path/to/firebase-credentials.json
# Option B: base64-encoded JSON (recommended for containers/env vars)
# FIREBASE_CREDENTIALS_JSON=base64EncodedServiceAccountJson

# Azure Communication Services (Email)
ACS_CONNECTION_STRING=endpoint=https://acs-sentinel-he.communication.azure.com/;accesskey=...
# Get your verified sender address from the ACS portal after domain verification
ACS_SENDER_ADDRESS=DoNotReply@your-domain.azurecomm.net

# Patient contacts (PoC: hardcoded. Production: query from User Service)
# Format: patientId:fcmToken:email — comma-separated for multiple patients
PATIENT_CONTACTS=00000000-0000-0000-0000-000000000001:FCM_TOKEN_HERE:patient@email.com

# Service
PORT=8080
LOG_LEVEL=info
SERVICE_NAME=alerts-service
