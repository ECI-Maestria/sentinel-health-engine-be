# ============================================================
# Telemetry Service — Environment Variables
# Copy this file to .env and fill in the real values.
# Run infra/azure/02-configure-secrets.sh to get all values.
# ============================================================

# Azure IoT Hub — Event Hub compatible endpoint
# Get with: az iot hub connection-string show --hub-name iothub-sentinel-he --policy-name service --query connectionString -o tsv
IOTHUB_EVENTHUB_CONNECTION_STRING=Endpoint=sb://...

# IoT Hub internal Event Hub name
# Get with: az iot hub show --name iothub-sentinel-he --query "properties.eventHubEndpoints.events.path" -o tsv
IOTHUB_EVENTHUB_NAME=iothub-ehub-iothub-sentinel-he-...

# Dedicated consumer group (created in 01-create-resources.sh)
IOTHUB_CONSUMER_GROUP=telemetry-service

# Azure Blob Storage for Event Hub checkpointing (use Azurite locally)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
CHECKPOINT_CONTAINER_NAME=iothub-checkpoints

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://sbns-sentinel-he.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...
TELEMETRY_TOPIC_NAME=telemetry-received

# Azure Cosmos DB
COSMOS_ENDPOINT=https://cosmos-sentinel-he.documents.azure.com:443/
COSMOS_KEY=your-primary-key-here==
COSMOS_DATABASE=sentinel-health
COSMOS_CONTAINER=telemetry

# Authorized devices (PoC): format = deviceId:patientId,deviceId2:patientId2
# In production this queries the Registration bounded context
AUTHORIZED_DEVICES=mobile-gateway-01:00000000-0000-0000-0000-000000000001

# Service
PORT=8080
LOG_LEVEL=info
SERVICE_NAME=telemetry-service
